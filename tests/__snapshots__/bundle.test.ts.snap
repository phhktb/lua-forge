exports[`bundle flat mode > snapshot flat output 1`] = `
"local function __lf_require(name)
  error("lua-forge: module '" .. name .. "' ไม่ถูก bundle " ..
    "(target=fivem ไม่มี global require) — เพิ่ม module เข้า bundle หรือกำหนด config.runtimeRequire", 2)
end

local __mod_format_0 = (function()
  local format = {}

  function format.bold(text)
    return "**" .. text .. "**"
  end

  return format
end)()

local __mod_utils_1 = (function()
  local format = __mod_format_0

  local utils = {}

  function utils.greet(name)
    return format.bold("hello " .. name)
  end

  return utils
end)()

local __mod_config_2 = (function()
  return {
    name = "fivem",
    version = "1.0.0",
  }
end)()

local utils = __mod_utils_1
local config = __mod_config_2
local json = __lf_require("json")

local function start()
  print(utils.greet(config.name))
  return json.encode({ ok = true })
end

start()
"
