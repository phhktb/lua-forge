{
  "name": "lua-forge",
  "version": "0.1.0",
  "description": "Fast, modular Lua bundler — combine many Lua files into one",
  "keywords": [
    "lua",
    "bundler",
    "require",
    "bundle",
    "module"
  ],
  "type": "module",
  "license": "MIT",
  "bin": {
    "lua-forge": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "cac": "^6.7.14",
    "luaparse": "^0.3.1"
  },
  "devDependencies": {
    "@types/luaparse": "^0.2.12",
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=18"
  }
}
